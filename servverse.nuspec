<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>servverse</id>
    <version>1.7.0</version>
    <title>ServVerse Unified Ecosystem Setup</title>
    <authors>Yuvaraj</authors>
    <owners>Yuvaraj</owners>
    <projectUrl>https://github.com/vyuvaraj/servverse-repo</projectUrl>
    <licenseUrl>https://github.com/vyuvaraj/servverse-repo/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>The ServVerse Developer Platform Unified Installer. Installs the 16 ecosystem components including Serv-lang compiler, ServGate, ServStore, ServQueue, ServCache, ServMesh, ServConsole, ServTrace, ServAuth, ServCron, ServCloud, ServFlow, ServPool, ServMail, ServTunnel, ServRegistry, and ServLock.</description>
    <summary>Servverse developer ecosystem unified package</summary>
    <tags>servverse serv-lang api-gateway s3 stomp message-broker microservices development</tags>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
